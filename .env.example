# S3 Browser Configuration
# Required environment variables

# S3 endpoint URL (e.g., http://localhost:3900, https://s3.amazonaws.com)
S3_ENDPOINT=

# AWS region (e.g., us-east-1)
S3_REGION=

# AWS access key ID
S3_ACCESS_KEY_ID=

# AWS secret access key
S3_SECRET_ACCESS_KEY=

# S3 bucket name
S3_BUCKET=

# Optional configurations

# Server port (default: 8080)
PORT=8080

# Allowed CORS origins (comma-separated, default: *)
# Examples:
# - "*" (allow all origins, not recommended for production)
# - "http://localhost:3000,http://localhost:8080"
# - "https://example.com"
ALLOWED_ORIGINS=*

# Debug logging (set to "true" to enable detailed logs)
DEBUG=false

# HTTP client timeout in seconds (0 = no timeout)
HTTP_TIMEOUT=0